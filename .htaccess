# MyCovai root .htaccess – central routing and sitemap management
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Force HTTPS - Redirect HTTP to HTTPS (must be first)
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www (canonical domain) - ensures HTTPS
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Security: disable indexes (may not work on all shared hosts)
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Phase 6: 301 redirects from old path names to new (keep bookmarks/backlinks working)
RewriteRule ^about-myomr-omr-community-portal\.php$ /about.php [R=301,L]
RewriteRule ^contact-my-omr-team\.php$ /contact.php [R=301,L]
RewriteRule ^webmaster-contact-my-omr\.php$ /webmaster-contact.php [R=301,L]
RewriteRule ^terms-and-conditions-my-omr\.php$ /terms-and-conditions.php [R=301,L]
RewriteRule ^website-privacy-policy-of-my-omr\.php$ /privacy-policy.php [R=301,L]
RewriteRule ^general-data-policy-of-my-omr\.php$ /data-policy.php [R=301,L]
RewriteRule ^info/website-privacy-policy-of-my-omr\.php$ /privacy-policy.php [R=301,L]
RewriteRule ^omr-listings(/.*)?$ /directory$1 [R=301,L]
RewriteRule ^omr-local-job-listings(/.*)?$ /jobs$1 [R=301,L]
RewriteRule ^omr-local-events(/.*)?$ /local-events$1 [R=301,L]
RewriteRule ^omr-hostels-pgs(/.*)?$ /hostels-pgs$1 [R=301,L]
RewriteRule ^omr-coworking-spaces(/.*)?$ /coworking-spaces$1 [R=301,L]
RewriteRule ^discover-myomr(/.*)?$ /discover$1 [R=301,L]
# Legacy MyOMR /events/ folder → canonical MyCovai /local-events/
RewriteRule ^events/?$ /local-events/ [R=301,L]
RewriteRule ^events/(.+)$ /local-events/$1 [R=301,L]

# Root sitemap index + static hub pages sitemap
RewriteRule ^sitemap\.xml$ weblog/generate-sitemap-index.php [L]
RewriteRule ^pages-sitemap\.xml$ weblog/generate-static-sitemap.php [L]

# Module: Events – clean routes (Phase 6: local-events/ to avoid clash with existing events/)
RewriteRule ^local-events/sitemap\.xml$ local-events/generate-events-sitemap.php [L]
RewriteRule ^local-events/event/([^/]+)/?$ local-events/event-detail-covai.php?slug=$1 [L,QSA]
RewriteRule ^local-events/category/([^/]+)/?$ local-events/category.php?slug=$1 [L,QSA]
RewriteRule ^local-events/locality/([^/]+)/?$ local-events/locality.php?slug=$1 [L,QSA]
RewriteRule ^local-events/venue/([^/]+)/?$ local-events/venue.php?slug=$1 [L,QSA]
RewriteRule ^local-events/today/?$ local-events/today.php [L,QSA]
RewriteRule ^local-events/weekend/?$ local-events/weekend.php [L,QSA]
RewriteRule ^local-events/month/?$ local-events/month.php [L,QSA]
RewriteRule ^local-events/post/?$ local-events/post-event-covai.php [L,QSA]
# Events: legacy *-omr.php filenames → *-covai.php (bookmarks, old links)
RewriteRule ^local-events/post-event-omr\.php$ /local-events/post-event-covai.php [R=301,L,QSA]
RewriteRule ^local-events/event-detail-omr\.php$ /local-events/event-detail-covai.php [R=301,L,QSA]
RewriteRule ^local-events/process-event-omr\.php$ /local-events/process-event-covai.php [R=301,L,QSA]
RewriteRule ^local-events/event-submitted-success-omr\.php$ /local-events/event-submitted-success-covai.php [R=301,L,QSA]
RewriteRule ^local-events/admin/manage-events-omr\.php$ /local-events/admin/manage-events-covai.php [R=301,L,QSA]

# Module: Directory – sitemap (Phase 6: directory/ to avoid clash with existing listings/)
RewriteRule ^directory/sitemap\.xml$ directory/generate-listings-sitemap.php [L]
# Emergency & Civic Directory – pretty URL
RewriteRule ^emergency-civic-directory$ /directory/emergency-civic-directory.php [L,NC]

# Module: Job Portal – sitemap (Phase 6: jobs/)
RewriteRule ^jobs/sitemap\.xml$ jobs/generate-sitemap.php [L]
RewriteRule ^jobs/job-detail-omr\.php$ /jobs/job-detail-covai.php [R=301,L,QSA]
RewriteRule ^jobs/post-job-omr\.php$ /jobs/post-job-covai.php [R=301,L,QSA]
RewriteRule ^jobs/process-job-omr\.php$ /jobs/process-job-covai.php [R=301,L,QSA]
RewriteRule ^jobs/process-application-omr\.php$ /jobs/process-application-covai.php [R=301,L,QSA]
RewriteRule ^jobs/application-submitted-omr\.php$ /jobs/application-submitted-covai.php [R=301,L,QSA]
RewriteRule ^jobs/job-posted-success-omr\.php$ /jobs/job-posted-success-covai.php [R=301,L,QSA]
RewriteRule ^jobs/edit-job-omr\.php$ /jobs/edit-job-covai.php [R=301,L,QSA]
RewriteRule ^jobs/edit-employer-profile-omr\.php$ /jobs/edit-employer-profile-covai.php [R=301,L,QSA]
RewriteRule ^jobs/employer-dashboard-omr\.php$ /jobs/employer-dashboard-covai.php [R=301,L,QSA]
RewriteRule ^jobs/employer-landing-omr\.php$ /jobs/employer-landing-covai.php [R=301,L,QSA]
RewriteRule ^jobs/employer-login-omr\.php$ /jobs/employer-login-covai.php [R=301,L,QSA]
RewriteRule ^jobs/employer-logout-omr\.php$ /jobs/employer-logout-covai.php [R=301,L,QSA]
RewriteRule ^jobs/employer-register-omr\.php$ /jobs/employer-register-covai.php [R=301,L,QSA]
RewriteRule ^jobs/my-posted-jobs-omr\.php$ /jobs/my-posted-jobs-covai.php [R=301,L,QSA]
RewriteRule ^jobs/update-application-status-omr\.php$ /jobs/update-application-status-covai.php [R=301,L,QSA]
RewriteRule ^jobs/view-applications-omr\.php$ /jobs/view-applications-covai.php [R=301,L,QSA]
RewriteRule ^jobs/admin/manage-jobs-omr\.php$ /jobs/admin/manage-jobs-covai.php [R=301,L,QSA]
RewriteRule ^jobs/admin/verify-employers-omr\.php$ /jobs/admin/verify-employers-covai.php [R=301,L,QSA]
RewriteRule ^jobs/admin/view-all-applications-omr\.php$ /jobs/admin/view-all-applications-covai.php [R=301,L,QSA]
RewriteRule ^jobs/([a-z0-9-]+)-([0-9]+)/?$ jobs/job-detail-covai.php?slug=$1&id=$2 [L,QSA,NC]
RewriteRule ^jobs/([0-9]+)/?$ jobs/job-detail-covai.php?id=$1 [L,QSA]

# Module: Hostels & PGs – sitemap (Phase 6: hostels-pgs/)
RewriteRule ^hostels-pgs/sitemap\.xml$ hostels-pgs/generate-sitemap.php [L]

# Module: Coworking Spaces – sitemap (Phase 6: coworking-spaces/)
RewriteRule ^coworking-spaces/sitemap\.xml$ coworking-spaces/generate-sitemap.php [L]

# Module: Coimbatore Elections 2026 – sitemap
RewriteRule ^coimbatore-elections-2026/sitemap\.xml$ coimbatore-elections-2026/generate-sitemap.php [L]

# Add more modules here when ready (news) with similar patterns

# Retired OMR listings landers → Covai directory hub
RewriteRule ^listings/.*$ /directory/ [R=301,L]

# Retired Pentahive OMR marketing microsite
RewriteRule ^pentahive(?:/.*)?$ / [R=301,L]

# Retired Chennai AC BLO search (OMR-era)
RewriteRule ^info/find-blo-officer\.php$ /coimbatore-elections-2026/ [R=301,L,QSA]
RewriteRule ^info/process-blo-subscription\.php$ /coimbatore-news.php [R=301,L]

# Retired OMR info pages → Covai equivalents (preserve SEO via 301)
RewriteRule ^info/citizens-charter-old-mahabali-puram-road\.php$ /about.php [R=301,L]
RewriteRule ^info/pallikaranai-marsh-ramsar-wetland\.php$ /coimbatore-news.php [R=301,L]
RewriteRule ^info/report-civic-issue-omr\.php$ /contact.php [R=301,L]
RewriteRule ^info/onboarding/getting-started\.php$ /discover/getting-started.php [R=301,L]
RewriteRule ^info/onboarding/features\.php$ /discover/features.php [R=301,L]
RewriteRule ^info/onboarding/community\.php$ /discover/community.php [R=301,L]
RewriteRule ^weblog/contact-my-omr-team\.php$ /contact.php [R=301,L]
RewriteRule ^weblog/general-data-policy-of-my-omr\.php$ /data-policy.php [R=301,L]
RewriteRule ^free-ads-chennai(?:/.*)?$ / [R=301,L]

# Legacy thank-you HTML → PHP (subscribe flow)
RewriteRule ^thank-you\.html$ /thank-you.php [R=301,L]
RewriteRule ^components/thank-you\.html$ /thank-you.php [R=301,L]
RewriteRule ^info/thank-you\.html$ /thank-you.php [R=301,L]

# Custom error pages (fail-safe)
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

# Block legacy unauthenticated news upload endpoint (security audit Phase 1)
RewriteRule ^admin/updatenewsform\.php$ - [F,L]

# Job landing pages: OMR Chennai URLs → Coimbatore canonical pages (AdSense site-focus cleanup)
RewriteRule ^jobs-in-omr-chennai\.php$ /jobs-in-coimbatore.php [R=301,L]
RewriteRule ^jobs-in-perungudi-omr\.php$ /jobs-in-rs-puram.php [R=301,L]
RewriteRule ^jobs-in-sholinganallur-omr\.php$ /jobs-in-gandhipuram.php [R=301,L]
RewriteRule ^jobs-in-navalur-omr\.php$ /jobs-in-peelamedu.php [R=301,L]
RewriteRule ^jobs-in-thoraipakkam-omr\.php$ /jobs-in-saravanampatti.php [R=301,L]
RewriteRule ^jobs-in-kelambakkam-omr\.php$ /jobs-in-saibaba-colony.php [R=301,L]
RewriteRule ^it-jobs-omr-chennai\.php$ /it-jobs-coimbatore.php [R=301,L]

# Retired OMR IT parks pages
RewriteRule ^directory/it-parks-in-omr\.php$ /directory/it-parks.php [R=301,L]
RewriteRule ^discover/it-parks-in-omr\.php$ /it-parks [R=301,L]

# Retired OMR job SEO landers in /weblog/ (robots disallow; redirect for bookmarks)
RewriteRule ^weblog/experienced-jobs-omr-chennai\.php$ /jobs-in-coimbatore.php [R=301,L]
RewriteRule ^weblog/healthcare-jobs-omr-chennai\.php$ /jobs-in-coimbatore.php [R=301,L]
RewriteRule ^weblog/hospitality-jobs-omr-chennai\.php$ /jobs-in-coimbatore.php [R=301,L]

# Coimbatore directory list – canonical covai-directory-list (replaces omr-road-database-list)
RewriteRule ^covai-directory-list\.php$ core/covai-directory-list.php [L]
RewriteRule ^omr-road-database-list\.php$ /covai-directory-list.php [R=301,L]
RewriteRule ^core/omr-road-database-list\.php$ /covai-directory-list.php [R=301,L]

# Security headers (safe defaults)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Content-Security-Policy can be tightened later after CDN audit
  # Header set Content-Security-Policy "default-src 'self' https: 'unsafe-inline' 'unsafe-eval'"
</IfModule>

# Static asset caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType image/webp "access plus 90 days"
  ExpiresByType image/jpeg "access plus 90 days"
  ExpiresByType image/png "access plus 90 days"
  ExpiresByType image/svg+xml "access plus 90 days"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/x-javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType font/ttf "access plus 30 days"
  ExpiresDefault "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>

# Environment
<IfModule mod_env.c>
  SetEnv MYCOVAI_ENV production
</IfModule>
# PHP error handler – disabled by default; some shared hosts block php_value in .htaccess
# Uncomment if your host allows it:
# <IfModule mod_php7.c>
#   php_value auto_prepend_file core/error-handler.php
# </IfModule>
# <IfModule mod_php8.c>
#   php_value auto_prepend_file core/error-handler.php
# </IfModule>

# Clean URLs for directories
# Banks list and details (Phase 6: directory/)
RewriteRule ^banks/?$ directory/banks.php [L]
RewriteRule ^banks/([A-Za-z0-9\-]+)$ directory/bank.php?slug=$1 [L,QSA]

# Hospitals list and details
RewriteRule ^hospitals/?$ directory/hospitals.php [L]
RewriteRule ^hospitals/([A-Za-z0-9\-]+)$ directory/hospital.php?slug=$1 [L,QSA]

# Schools list and details
RewriteRule ^schools/?$ directory/schools.php [L]
RewriteRule ^schools/([A-Za-z0-9\-]+)$ directory/school.php?slug=$1 [L,QSA]

# Parks list and details
RewriteRule ^parks/?$ directory/parks.php [L]
RewriteRule ^parks/([A-Za-z0-9\-]+)$ directory/park.php?slug=$1 [L,QSA]

# Industries list and details
RewriteRule ^industries/?$ directory/industries.php [L]
RewriteRule ^industries/([A-Za-z0-9\-]+)$ directory/industry.php?slug=$1 [L,QSA]

# Government offices list and details
RewriteRule ^government-offices/?$ directory/government-offices.php [L]
RewriteRule ^government-offices/([A-Za-z0-9\-]+)$ directory/government-office.php?slug=$1 [L,QSA]

# ATMs list and details
RewriteRule ^atms/?$ directory/atms.php [L]
RewriteRule ^atms/([A-Za-z0-9\-]+)$ directory/atm.php?slug=$1 [L,QSA]

# Pretty URL for IT companies listing (Phase 6: directory/)
RewriteRule ^it-companies$ /directory/it-companies.php [L,NC]
RewriteRule ^it-companies/([A-Za-z0-9-]+)$ /directory/it-company.php?slug=$1 [L,NC,QSA]

# Pretty URL for IT parks listing
RewriteRule ^it-parks$ /directory/it-parks.php [L,NC]
RewriteRule ^it-parks/([A-Za-z0-9-]+)$ /directory/it-park.php?slug=$1 [L,NC,QSA]
RewriteRule ^it-parks/sitemap\.xml$ /directory/generate-it-parks-sitemap.php [L]

# Pretty URL for Hospitals listing
RewriteRule ^hospitals$ /directory/hospitals.php [L,NC]
RewriteRule ^hospitals/([A-Za-z0-9-]+)$ /directory/hospital.php?slug=$1 [L,NC,QSA]

# Pretty URL for Banks listing
RewriteRule ^banks$ /directory/banks.php [L,NC]
RewriteRule ^banks/([A-Za-z0-9-]+)$ /directory/bank.php?slug=$1 [L,NC,QSA]

# Pretty URL for Schools listing
RewriteRule ^schools$ /directory/schools.php [L,NC]
RewriteRule ^schools/([A-Za-z0-9-]+)$ /directory/school.php?slug=$1 [L,NC,QSA]

# Pretty URL for Restaurants listing
RewriteRule ^restaurants$ /directory/restaurants.php [L,NC]
RewriteRule ^restaurants/([A-Za-z0-9-]+)$ /directory/restaurant.php?slug=$1 [L,NC,QSA]

# Pretty URL for Industries listing
RewriteRule ^industries$ /directory/industries.php [L,NC]
RewriteRule ^industries/([A-Za-z0-9-]+)$ /directory/industry.php?slug=$1 [L,NC,QSA]

# Pretty URL for Parks listing
RewriteRule ^parks$ /directory/parks.php [L,NC]
RewriteRule ^parks/([A-Za-z0-9-]+)$ /directory/park.php?slug=$1 [L,NC,QSA]


# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php82" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# Local news – article sitemap (must be before slug catch-all)
RewriteRule ^local-news/sitemap\.xml$ local-news/generate-sitemap.php [L]

# Retired OMR static local-news/*.php files → Covai news hub (infra allowlist)
RewriteCond %{REQUEST_URI} ^/local-news/[^/]+\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/article\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/event-recap\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/generate-sitemap\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/news-highlights\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/news-highlights-from-omr-road\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/local-news/article-sports-seo-enhancement\.php$ [NC]
RewriteRule ^local-news/[^/]+\.php$ /coimbatore-news.php [R=301,L]

# Clean URLs for articles: /local-news/article-slug -> article.php?slug=article-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/local-news/([^/]+)/?$
RewriteRule ^local-news/([^/]+)/?$ local-news/article.php?slug=$1 [L,QSA]

</IfModule>
